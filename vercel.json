{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/parse",
      "dest": "/api/parse.js"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
